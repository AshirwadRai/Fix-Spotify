{
  "$schema": "https://schema.tauri.app/config/2/capability.schema.json",
  "identifier": "default",
  "description": "Default capabilities for Fix_Spotify",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-unmaximize",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "clipboard-manager:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-create",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:scope-app",
    "fs:scope-appdata",
    "fs:scope-document",
    "fs:scope-download",
    "fs:scope-temp",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "shell:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-execute",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-load",
    "store:allow-save",
    "notification:default",
    "notification:allow-show",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}