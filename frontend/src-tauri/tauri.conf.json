{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fix_Spotify",
  "version": "1.1.0",
  "identifier": "com.xmrnoobx.fixspotify",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fix_Spotify",
        "width": 1200,
        "height": 800,
        "center": true,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "hiddenTitle": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https:; font-src 'self' data: https:; media-src 'self' blob: https: http://127.0.0.1:* http://localhost:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "android": {
      "minSdkVersion": 29,
      "versionCode": 1
    },
    "externalBin": [
      "backend"
    ],
    "resources": {
      "../../vendor/bin/*": "bin/"
    },
    "copyright": "Copyright \u00a9 2024 XMrNooBX",
    "shortDescription": "Multi-source music downloader",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDNTAzNDJCNThFRjdBRjAKUldUd2V1OVlLelJRWEF2eG1yRmhCWUhKQUFacDdGVjhvczdNZDJ1bHoxZk9PQ09Qcm5IZVJrdGkK",
      "endpoints": [
        "https://github.com/XMrNooBX/Fix-Spotify/releases/latest/download/latest.json"
      ]
    }
  }
}
